<?xml version="1.0" encoding="utf-8"?>
<!-- Boton Glass primario (cyan brillante) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="135"
                android:startColor="@color/neonBlue"
                android:endColor="@color/accentCyan"
                android:type="linear" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="135"
                android:startColor="#55FFFFFF"
                android:centerColor="#15FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <stroke android:width="1dp" android:color="#88FFFFFF" />
        </shape>
    </item>
</layer-list>
