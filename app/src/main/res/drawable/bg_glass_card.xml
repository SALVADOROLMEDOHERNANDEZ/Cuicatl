<?xml version="1.0" encoding="utf-8"?>
<!-- Tarjeta Glass (intensa) - frosted con borde neón cyan -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="@color/glass_surface" />
            <stroke android:width="1dp" android:color="@color/glass_stroke_cyan_soft" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="135"
                android:startColor="#33FFFFFF"
                android:centerColor="#0DFFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
