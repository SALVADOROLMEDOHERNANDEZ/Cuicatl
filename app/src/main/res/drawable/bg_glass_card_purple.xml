<?xml version="1.0" encoding="utf-8"?>
<!-- Glass mas oscuro con resplandor neon purple -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="@color/glass_surface_dark" />
            <stroke android:width="1dp" android:color="@color/glass_stroke_purple_soft" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="135"
                android:startColor="#22D500F9"
                android:centerColor="#0700E5FF"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
