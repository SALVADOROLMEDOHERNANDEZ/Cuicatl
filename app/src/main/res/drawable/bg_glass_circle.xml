<?xml version="1.0" encoding="utf-8"?>
<!-- Circulo glass para iconos / botones flotantes -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/glass_surface" />
            <stroke android:width="1dp" android:color="@color/glass_stroke_cyan" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
