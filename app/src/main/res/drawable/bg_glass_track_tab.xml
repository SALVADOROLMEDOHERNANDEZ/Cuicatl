<?xml version="1.0" encoding="utf-8"?>
<!-- Track tab pill -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp"/>
                    <gradient android:angle="135" android:startColor="#3300E5FF" android:endColor="#22D500F9"/>
                    <stroke android:width="1dp" android:color="@color/neonBlue"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="@color/glass_surface_dark"/>
            <stroke android:width="1dp" android:color="@color/glass_stroke_white"/>
        </shape>
    </item>
</selector>
