<?xml version="1.0" encoding="utf-8"?>
<!-- Item de cancion: glass sutil con borde cyan -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/glass_surface_dark" />
            <stroke android:width="1dp" android:color="@color/glass_stroke_cyan_soft" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="135"
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
