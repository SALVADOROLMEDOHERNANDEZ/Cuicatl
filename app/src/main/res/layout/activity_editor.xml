<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/futuristic_background"
    android:padding="14dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/llEditorHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_glass_card"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnEditorBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_glass_circle"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white"
                android:contentDescription="@string/content_desc_back"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/editor_title"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:shadowColor="@color/neonBlue"
                android:shadowRadius="14"/>

            <ImageButton
                android:id="@+id/btnAddTrack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_glass_circle"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/neonBlue"
                android:contentDescription="@string/editor_add_track"/>

            <ImageButton
                android:id="@+id/btnReset"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_glass_circle"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/neonPurple"
                android:contentDescription="@string/editor_reset"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/editor_subtitle"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Track Selector -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTrackSelector"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/llEditorHeader"
        tools:listitem="@layout/item_track_tab"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/rvTrackSelector"
        app:layout_constraintBottom_toTopOf="@id/clMiniControl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Selected Track Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="18dp">
                <ImageView
                    android:id="@+id/ivEditorArt"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:src="@drawable/disc_visual"
                    android:contentDescription="Art"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:id="@+id/tvEditorSong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/editor_no_track"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvEditorArtist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/editor_select_track"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Waveform LIVE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/editor_waveform"
                android:textColor="@color/neonBlue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.18"
                android:layout_marginBottom="6dp"/>

            <com.example.cuicatl.views.WaveformVisualizerView
                android:id="@+id/waveform"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_glass_card_purple"
                android:layout_marginBottom="20dp"/>

            <!-- Tabs Eq / Effects / Trim -->
            <LinearLayout
                android:id="@+id/llEditorTabs"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_glass_tabs"
                android:padding="4dp"
                android:layout_marginBottom="18dp">
                <TextView
                    android:id="@+id/tabEqualizer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/editor_tab_eq"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:background="@drawable/bg_glass_pill_selector"
                    android:activated="true"/>
                <TextView
                    android:id="@+id/tabEffects"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/editor_tab_effects"
                    android:textColor="@color/text_muted"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:background="@drawable/bg_glass_pill_selector"/>
                <TextView
                    android:id="@+id/tabTrim"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/editor_tab_trim"
                    android:textColor="@color/text_muted"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:background="@drawable/bg_glass_pill_selector"/>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/flEditorContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include android:id="@+id/equalizerLayout" layout="@layout/view_equalizer_controls" />
                <include android:id="@+id/effectsLayout" layout="@layout/view_effects_controls" android:visibility="gone" />
                <include android:id="@+id/trimLayout" layout="@layout/view_trim_controls" android:visibility="gone" />

            </FrameLayout>

            <Button
                android:id="@+id/btnExportMaster"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/editor_btn_export"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:background="@drawable/bg_glass_button_primary"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Mini Player Glass -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMiniControl"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@drawable/bg_glass_card"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageView
            android:id="@+id/ivSmallArt"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/disc_visual"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="Art"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivSmallArt"
            app:layout_constraintEnd_toStartOf="@id/llMiniButtons">
            <TextView
                android:id="@+id/tvSmallTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Track"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/tvSmallArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playback inactive"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/llMiniButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="14dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageButton android:id="@+id/btnEditorPrev" android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_glass_circle" android:src="@android:drawable/ic_media_previous"
                app:tint="@color/white" android:contentDescription="Prev"/>
            <ImageButton android:id="@+id/btnEditorPlay" android:layout_width="46dp" android:layout_height="46dp"
                android:background="@drawable/bg_glass_circle" android:src="@android:drawable/ic_media_play"
                app:tint="@color/neonBlue" android:layout_marginHorizontal="8dp" android:contentDescription="Play"/>
            <ImageButton android:id="@+id/btnEditorNext" android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_glass_circle" android:src="@android:drawable/ic_media_next"
                app:tint="@color/white" android:contentDescription="Next"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
