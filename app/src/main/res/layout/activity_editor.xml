<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E14"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/llEditorHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Audio Editor"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnAddTrack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/pro_badge_bg"
                app:backgroundTint="@color/neonBlue"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/black"
                android:contentDescription="Add Track" />

            <ImageButton
                android:id="@+id/btnReset"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/stat_notify_sync"
                app:tint="@color/white"
                android:contentDescription="Reset" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Professional multi-track tools"
            android:textColor="#888888"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Track Selector (Horizontal List) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTrackSelector"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/llEditorHeader"
        tools:listitem="@layout/item_track_tab"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/rvTrackSelector"
        app:layout_constraintBottom_toTopOf="@id/clMiniControl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Selected Track Info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1A1F26"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/ivEditorArt"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/disc_visual"
                        android:contentDescription="Art"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:id="@+id/tvEditorSong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Track Selected"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvEditorArtist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select a track to edit"
                            android:textColor="#888888"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Waveform Placeholder -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WAVEFORM"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="#1A1F26"
                android:layout_marginBottom="24dp"/>

            <!-- Tabs -->
            <LinearLayout
                android:id="@+id/llEditorTabs"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="#1A1F26"
                android:padding="4dp"
                android:layout_marginBottom="20dp">
                <TextView
                    android:id="@+id/tabEqualizer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Equalizer"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:background="@drawable/pro_badge_bg"
                    app:backgroundTint="#2A2F36"/>
                <TextView
                    android:id="@+id/tabEffects"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Effects &amp; Tools"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Equalizer View -->
            <FrameLayout
                android:id="@+id/flEditorContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include android:id="@+id/equalizerLayout" layout="@layout/view_equalizer_controls" />
                <include android:id="@+id/effectsLayout" layout="@layout/view_effects_controls" android:visibility="gone" />

            </FrameLayout>

            <Button
                android:id="@+id/btnExportMaster"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Export Project"
                android:backgroundTint="@color/neonBlue"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Mini Player -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMiniControl"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#1A1F26"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageView
            android:id="@+id/ivSmallArt"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/disc_visual"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="Art"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivSmallArt"
            app:layout_constraintEnd_toStartOf="@id/llMiniButtons">
            <TextView
                android:id="@+id/tvSmallTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Track"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvSmallArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playback inactive"
                android:textColor="#888888"
                android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/llMiniButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageButton android:id="@+id/btnEditorPrev" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_previous" app:tint="@color/white" android:contentDescription="Prev"/>
            <ImageButton android:id="@+id/btnEditorPlay" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_play" app:tint="@color/neonBlue" android:contentDescription="Play"/>
            <ImageButton android:id="@+id/btnEditorNext" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_next" app:tint="@color/white" android:contentDescription="Next"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
