<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/futuristic_background"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnBackFolders"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvFoldersTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CARPETAS DE MÚSICA"
        android:textColor="@color/neonBlue"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btnBackFolders"
        app:layout_constraintBottom_toBottomOf="@id/btnBackFolders"
        app:layout_constraintStart_toEndOf="@id/btnBackFolders"
        android:layout_marginStart="16dp"/>

    <TextView
        android:id="@+id/tvFoldersSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Selecciona las carpetas que deseas ver en la pantalla principal"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnBackFolders"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFolders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvFoldersSubtitle"
        app:layout_constraintBottom_toTopOf="@id/btnSaveFoldersSelection"/>

    <Button
        android:id="@+id/btnSaveFoldersSelection"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="APLICAR FILTRO"
        android:backgroundTint="@color/neonBlue"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
