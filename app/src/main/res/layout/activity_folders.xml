<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/futuristic_background"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/llFoldersHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_glass_card"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBackFolders"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_glass_circle"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white"/>

            <TextView
                android:id="@+id/tvFoldersTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CARPETAS DE MÚSICA"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:shadowColor="@color/neonBlue"
                android:shadowRadius="10"
                android:layout_marginStart="14dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvFoldersSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecciona las carpetas que deseas ver en la pantalla principal"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFolders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/llFoldersHeader"
        app:layout_constraintBottom_toTopOf="@id/btnSaveFoldersSelection"/>

    <Button
        android:id="@+id/btnSaveFoldersSelection"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="APLICAR FILTRO"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:background="@drawable/bg_glass_button_primary"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
