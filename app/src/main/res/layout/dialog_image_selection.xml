<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="18dp"
    android:background="@drawable/bg_glass_card">

    <TextView
        android:id="@+id/tvSelectImageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IA: Selecciona una Portada"
        android:textColor="@color/neonBlue"
        android:textSize="17sp"
        android:textStyle="bold"
        android:shadowColor="@color/neonBlue"
        android:shadowRadius="10"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvImageOptions"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectImageTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnCancelSelection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancelar"
        android:textColor="@color/white"
        android:background="@drawable/bg_glass_pill"
        android:paddingHorizontal="22dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/rvImageOptions"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
