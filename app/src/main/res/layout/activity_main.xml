<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/futuristic_background">

    <!-- Cyan Header with Title -->
    <androidx.cardview.widget.CardView
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_margin="8dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#80DEEA"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:src="@drawable/cuicatl"
                android:contentDescription="Cuicatl Logo" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Black Tabs Bar -->
    <LinearLayout
        android:id="@+id/llTabs"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@color/black"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <LinearLayout
            android:id="@+id/tabSongs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_canciones"
                android:layout_marginEnd="8dp"
                android:contentDescription="Icono Canciones"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Canciones"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabFolders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_folder"
                android:layout_marginEnd="8dp"
                android:contentDescription="Icono Carpetas"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Carpetas"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLibrary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/llTabs"
        app:layout_constraintBottom_toTopOf="@id/cvMiniPlayer"
        tools:listitem="@layout/item_song"/>

    <!-- Mini-Player with Image Background -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvMiniPlayer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#1A1F26"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toTopOf="@id/footerCard">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivMiniBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:alpha="0.4"
                android:contentDescription="Background"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:id="@+id/ivMiniDisc"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/disc_visual"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:contentDescription="Mini Disc"/>

                <LinearLayout
                    android:id="@+id/llMiniInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivMiniDisc"
                    app:layout_constraintEnd_toStartOf="@id/llMiniControls">

                    <TextView
                        android:id="@+id/tvMiniTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Título de la Canción"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:shadowColor="@color/black"
                        android:shadowRadius="4"/>

                    <TextView
                        android:id="@+id/tvMiniArtist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Artista"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:shadowColor="@color/black"
                        android:shadowRadius="2"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llMiniControls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageButton
                        android:id="@+id/btnMiniPrev"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_media_previous"
                        app:tint="@color/white"
                        android:contentDescription="Anterior"/>

                    <ImageButton
                        android:id="@+id/btnMiniPlayPause"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/pro_badge_bg"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/black"
                        android:layout_marginHorizontal="8dp"
                        android:contentDescription="Play/Pause"/>

                    <ImageButton
                        android:id="@+id/btnMiniNext"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="@color/white"
                        android:contentDescription="Siguiente"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Cyan Footer with Tools -->
    <androidx.cardview.widget.CardView
        android:id="@+id/footerCard"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_margin="8dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#80DEEA"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/btnMusic"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/musica"
                    android:padding="8dp"
                    android:contentDescription="Música"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Música"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnEditAudio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_edicion_audio"
                    android:padding="8dp"
                    android:contentDescription="Edición de audio"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edición de audio"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Hidden Mini-Player for current playback context -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvLibraryOverlay"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:visibility="gone"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="@color/surfaceColor"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
